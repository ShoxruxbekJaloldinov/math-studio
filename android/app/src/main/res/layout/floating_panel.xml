<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/floating_panel_background"
    android:elevation="12dp"
    android:clipToPadding="false"
    android:gravity="center_vertical"
    android:minWidth="190dp">

    <View
        android:id="@+id/statusDot"
        android:layout_width="7dp"
        android:layout_height="7dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/record_dot" />

    <Button
        android:id="@+id/btnPause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/button_circle_accent"
        android:text="⏸"
        android:textColor="#FF111111"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/button_circle_gray"
        android:foregroundGravity="center">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="00:00"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </FrameLayout>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/button_circle_stop"
        android:text="■"
        android:textColor="#FF111111"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:stateListAnimator="@null"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />
</LinearLayout>